        model.predict(X_test_norm, batch_size=256, verbose=0)
        times.append(time.time() - t0)
    inf_time = np.mean(times)
    complexity.append({
        'Model'              : name,
        'Parameters'         : params,
        'Inference Time (s)' : round(inf_time, 3),
        'Test Accuracy'      : metrics['Accuracy'],
        'F1-Score'           : metrics['F1-Score']
    })

